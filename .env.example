# ─────────────────────────────────────────────
# OpenOncology — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Database
DB_PASSWORD=change_me_strong_password

# MinIO / S3 Storage
MINIO_ACCESS_KEY=openoncology_admin
MINIO_SECRET_KEY=change_me_minio_secret

# FastAPI
SECRET_KEY=change_me_jwt_secret_min_32_chars
ENVIRONMENT=development

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin

# Grafana
GRAFANA_PASSWORD=change_me_grafana

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe (Crowdfunding / Payments)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# OncoKB (free academic token — apply at oncokb.org)
ONCOKB_API_TOKEN=

# OpenAI (for plain-language LLM summaries — optional, falls back to template)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# COSMIC (somatic mutation catalogue — free academic registration at cancer.sanger.ac.uk)
COSMIC_EMAIL=
COSMIC_PASSWORD=

# AWS / Cloud (optional — for production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_RAW=openoncology-raw
S3_BUCKET_VCF=openoncology-vcf
S3_BUCKET_REPORTS=openoncology-reports
